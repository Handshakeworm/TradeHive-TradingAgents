# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# ── 数据源 API Keys ────────────────────────────────────────────────────────

# Alpha Vantage（免费，股票/外汇/加密数据备选）
# 申请：https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# FRED 宏观经济数据（免费，必填才能使用 macro_data 类别）
# 申请（30秒）：https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Reddit 社交情绪（可选，不填仍可使用 VADER 新闻情绪）
# 申请：https://www.reddit.com/prefs/apps （选 script 类型）
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=tradehive_sentiment/1.0

# ── 本地数据缓存目录（可选，默认 ./data_cache） ────────────────────────────
# TRADEHIVE_CACHE_DIR=./data_cache
